APP_URL=http://localhost:3000
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname
MONGODB_DB_NAME=threeline_morning
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM_EMAIL=hello@mail.studiobyyou.kr
NEXT_PUBLIC_KAKAO_JAVASCRIPT_KEY=your-kakao-javascript-key
KAKAO_REST_API_KEY=your-kakao-rest-api-key
KAKAO_CLIENT_SECRET=your-kakao-client-secret
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
NAVER_CLIENT_ID=your-naver-oauth-client-id
NAVER_CLIENT_SECRET=your-naver-oauth-client-secret
# Optional until real production AI summarization is enabled.
PIXABAY_API_KEY=your-pixabay-api-key
# Google Cloud Text-to-Speech 서비스 계정 JSON (전체를 single-line으로 single quote로 감싸기)
# 예: GOOGLE_APPLICATION_CREDENTIALS_JSON='{"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}'
GOOGLE_APPLICATION_CREDENTIALS_JSON='{"type":"service_account","project_id":"your-project-id","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"tts@your-project.iam.gserviceaccount.com","client_id":"..."}'
# Solapi 카카오 알림톡 발송 (모두 선택; 하나라도 없으면 카카오 발송 비활성화)
SOLAPI_API_KEY=your-solapi-api-key
SOLAPI_API_SECRET=your-solapi-api-secret
SOLAPI_PFID=KA01PF...
SOLAPI_TEMPLATE_ID=KA01TP...
# 발신번호 (숫자만 10~11자리. 예: 01012345678)
SOLAPI_SENDER_PHONE=01012345678
COUPANG_PARTNERS_ACCESS_KEY=your-coupang-partners-access-key
COUPANG_PARTNERS_SECRET_KEY=your-coupang-partners-secret-key
CRON_SECRET=replace-with-a-long-random-secret-at-least-32-chars
ADMIN_SESSION_SECRET=replace-with-a-different-long-random-secret
ADMIN_PASSWORD=replace-with-a-long-admin-password
ADMIN_EMAIL_ALLOWLIST=admin@example.com
